# LLM Provider: "openai", "anthropic", or "deepseek"
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Optional: override SessionMiddleware secret (min 16 chars). If unset, secret is stored in SQLite app_meta.
# APP_SESSION_SECRET=

# Comma-separated browser origins when using session cookies (dev + your production URL).
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

